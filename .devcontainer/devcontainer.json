{
  "name": "TradingChassis Core Runtime Dev",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:2": {}
  },
  "workspaceFolder": "/workspaces/ops-lab",
  "remoteUser": "root",
  "runArgs": ["--security-opt=label=disable"],
  "forwardPorts": [8000, 9090, 3000],
  "containerEnv": {
    "SHELL": "/bin/bash"
  }
}
